    {
      "parameters": {
        "jsCode": "return {{ (function(){\n  var researchData = $node['read_research_data'].json;\n  var scoringData = $node['read_scoring_data'].json;\n  var projectId = $node['webhook_trigger'].json.body.project_id;\n  var prdTitle = $node['webhook_trigger'].json.body.prd_title;\n  var targetRelease = $node['webhook_trigger'].json.body.target_release;\n  var successMetrics = $node['webhook_trigger'].json.body.success_metrics || [];\n  \n  var scoredCapabilities = [];\n  if (scoringData && Array.isArray(scoringData)) {\n    scoredCapabilities = scoringData\n      .filter(function(item) { return item.project_id === projectId; })\n      .sort(function(a, b) { return (b.score || 0) - (a.score || 0); })\n      .slice(0, 10);\n  }\n  \n  var context = {\n    projectId: projectId,\n    prdTitle: prdTitle,\n    targetRelease: targetRelease,\n    successMetrics: successMetrics,\n    researchSummary: researchData,\n    topCapabilities: scoredCapabilities\n  };\n  \n  var prompt = 'You are a senior product manager. Generate a comprehensive PRD based on the following research and scoring data:\\n\\n';\n  prompt += 'PROJECT: ' + prdTitle + '\\n';\n  prompt += 'TARGET RELEASE: ' + targetRelease + '\\n';\n  prompt += 'SUCCESS METRICS: ' + JSON.stringify(successMetrics) + '\\n\\n';\n  prompt += 'RESEARCH DATA:\\n' + JSON.stringify(researchData, null, 2) + '\\n\\n';\n  prompt += 'TOP SCORED CAPABILITIES:\\n' + JSON.stringify(scoredCapabilities, null, 2) + '\\n\\n';\n  prompt += 'Generate a detailed PRD including: Executive Summary, Problem Statement, Target User, Key Features, Success Criteria, and Implementation Timeline.';\n  \n  return { context: context, prompt: prompt };\n})()} }}"
      },
      "id": "prepare_prd_context",
      "name": "Prepare PRD Context",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        700,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "model",
              "value": "claude-sonnet-4-20250514"
            },
            {
              "name": "max_tokens",
              "value": "8000"
            },
            {
              "name": "messages",
              "value": "={{ [ { role: 'user', content: $node['prepare_prd_context'].json.prompt } ] }}"
            },
            {
              "name": "system",
              "value": "You are a senior product manager with expertise in creating comprehensive Product Requirements Documents. Your PRDs should include clear problem statements, user personas, feature specifications, success metrics, and implementation roadmaps. Format the output as clean markdown with proper headings and structure."
            }
          ]
        },
        "options": {
          "headers": {
            "anthropic-version": "2023-06-01"
          }
        }
      },
      "credentials": {
        "httpHeaderAuth": "anthropic_api"
      },
      "id": "generate_prd_claude",
      "name": "Generate PRD via Claude",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        950,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "var response = $node['generate_prd_claude'].json;\nvar prdContent = '';\n\nif (response.content && Array.isArray(response.content)) {\n  response.content.forEach(function(block) {\n    if (block.type === 'text') {\n      prdContent += block.text;\n    }\n  });\n}\n\nreturn {\n  prd_markdown: prdContent,\n  project_id: $node['webhook_trigger'].json.body.project_id,\n  generated_at: new Date().toISOString()\n};"
      },
